// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Users {
    id                      String                  @id @default(uuid())
    email                   String                  @unique
    password                String
    firstname               String
    lastname                String
    middlename              String?
    username                String                  @unique
    avatarId                Int?                    @unique
    backgroundId            Int?                    @unique

    postsCount              Int                     @default(0)
    coursesCount            Int                     @default(0)
    followersCount          Int                     @default(0)
    followingCount          Int                     @default(0)
    subscribersCount        Int                     @default(0)
    ratingCount             Int                     @default(0)
    ratingTotal             Float                   @default(0)
    rating                  Float                   @default(0)

    sessionVersion          Int                     @default(0)
    createdAt               DateTime                @default(now())

    avatar                  Photo?                  @relation("UserAvatar", fields: [avatarId], references: [id])
    background              Photo?                  @relation("UserBackground", fields: [backgroundId], references: [id])

    passwordResetTokens     PasswordResetToken[]
    posts                   Post[]
    course                  Course[]
    subscribe               Subscribe[]
    followers               Follow[]                @relation("userFollowers")
    following               Follow[]                @relation("userFollowing")
    discussions             Discussion[]
    ratePosts               RatePost[]
    rateDiscussion          RateDiscussion[]
    experience              Experience[]
    educations              Education[]
    projects                Project[]
    projectContributors     ProjectContributor[]
    uploadedFiles           File[]
    uploadedPhotos          Photo[]                 @relation("UploadedPhoto")
    
    @@map("users")
}

model PasswordResetToken {
    id              String      @id @default(uuid())
    userId          String
    token           String
    expiresAt       DateTime
    used            Boolean     @default(false)
    createdAt       DateTime    @default(now())

    user            Users       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("password_reset_tokens")
}

model Follow {
    followerId      String
    followingId     String

    follower        Users       @relation("userFollowing", fields: [followerId], references: [id], onDelete: Cascade)
    following       Users       @relation("userFollowers", fields: [followingId], references: [id], onDelete: Cascade)

    createdAt       DateTime    @default(now())

    @@unique([followerId, followingId]) // prevents duplicate follows
    @@index([followingId])
    @@map("follow")
}

model Course {
    id                  String      @id @default(uuid())
    title               String?
    description         String?
    userId              String
    price               Float       @default(0)
    currency            String      @default("AUD")
    thumbnailId         Int?        @unique

    subscribersCount    Int         @default(0)
    postsCount          Int         @default(0)
    ratingCount         Int         @default(0)
    ratingTotal         Float       @default(0)
    rating              Float       @default(0)

    createdAt           DateTime    @default(now())

    user                Users       @relation(fields: [userId], references: [id], onDelete: Cascade)
    thumbnail           Photo?      @relation(fields: [thumbnailId], references: [id])

    subscribers         Subscribe[]
    posts               PostInCourse[]
    folders             FolderInCourse[]
    files               FileInCourse[]

    @@unique([userId, title])   // Prevent 2 courses having the same name
    @@index([userId])
    @@map("course")
}

model Subscribe {
    id              String      @id @default(uuid())

    courseId        String
    userId          String
    review          String?
    rating          Float       @default(0)
    price           Float       @default(0)
    currency        String      @default("AUD")

    createdAt       DateTime    @default(now())

    course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
    subscriber     Users        @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([courseId, userId])
    @@index([courseId])
    @@map("subscribe")
}

model Post {
    id              String      @id @default(uuid())
    title           String?
    content         Json?
    userId          String

    // rating = ratingTotal / ratingCount
    ratingCount     Int         @default(0)
    ratingTotal     Float       @default(0)
    rating          Float       @default(0)
    createdAt       DateTime    @default(now())

    user            Users       @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    inCourses       PostInCourse[]
    discussions     Discussion[]
    ratePosts       RatePost[]
    files           FileInPost[]

    @@index([userId])
    @@map("post")
}

model PostInCourse {
    courseId        String
    postId          String

    createdAt       DateTime    @default(now())

    course         Course       @relation(fields: [courseId], references: [id])
    post           Post         @relation(fields: [postId], references: [id])

    @@unique([courseId, postId])
    @@index([courseId])
    @@map("post_in_course")
}

model RatePost {
    id              String      @id @default(uuid())
    postId          String
    userId          String
    rating          Float       @default(5)

    createdAt       DateTime    @default(now())

    post            Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
    user            Users       @relation(fields: [userId], references: [id])

    @@unique([postId, userId])
    @@map("rate_post")
}

model Discussion {
    id                  String              @id @default(uuid())
    discussion          Json
    ratingCount         Int                 @default(0)
    ratingTotal         Float               @default(0)
    rating              Float               @default(5)
    postId              String
    userId              String
    createdAt           DateTime            @default(now())

    post                Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
    user                Users               @relation(fields: [userId], references: [id])

    repliedDiscussions  ReplyDiscussion[]   @relation("repliedDiscussion")
    replyingDiscussions ReplyDiscussion[]   @relation("replyingDiscussion")
    rateDiscussion      RateDiscussion[]

    @@index([postId])
    @@map("discussion")
}

model ReplyDiscussion {
    id                  String      @id @default(uuid())

    repliedId           String
    replyingId          String

    createdAt           DateTime    @default(now())

    repliedDiscussion   Discussion  @relation("repliedDiscussion", fields: [repliedId], references: [id], onDelete: Cascade)
    replyingDiscussion  Discussion  @relation("replyingDiscussion", fields: [replyingId], references: [id], onDelete: Cascade)

    @@index([repliedId])
    @@map("reply_discussion")
}

model RateDiscussion {
    id              String      @id @default(uuid())
    discussionId    String
    userId          String
    rating          Float       

    createdAt       DateTime    @default(now())

    discussion      Discussion  @relation(fields: [discussionId], references: [id], onDelete: Cascade)
    user            Users       @relation(fields: [userId], references: [id])

    @@unique([discussionId, userId])
    @@map("rate_dicussion")
}

model Experience {
    id              String      @id @default(uuid())
    name            String
    position        String?
    role            String?
    startedAt       DateTime?
    endedAt         DateTime?
    location        String?
    achievement     String?
    order           Int
    userId          String
    logoId          Int?        @unique

    createdAt       DateTime    @default(now())

    user            Users       @relation(fields: [userId], references: [id], onDelete: Cascade)
    logo            Photo?      @relation(fields: [logoId], references: [id])

    @@index([userId])
    @@map("experience")
}

model Education {
    id              String      @id @default(uuid())
    name            String
    major           String?
    degree          String?
    startedAt       DateTime?
    endedAt         DateTime?
    location        String?
    achievement     String?
    order           Int         
    userId          String
    logoId          Int?        @unique

    createdAt       DateTime    @default(now())

    user            Users       @relation(fields: [userId], references: [id], onDelete: Cascade)
    logo            Photo?      @relation(fields: [logoId], references: [id])

    @@index([userId])
    @@map("education")
}

model Project {
    id                      String                  @id @default(uuid())
    name                    String
    role                    String
    startedAt               DateTime?
    endedAt                 DateTime?
    details                 String?
    order                   Int
    userId                  String
    logoId                  Int?                    @unique

    createdAt               DateTime                @default(now())

    user                    Users                   @relation(fields: [userId], references: [id], onDelete: Cascade)
    logo                    Photo?                  @relation(fields: [logoId], references: [id])

    projectContributors     ProjectContributor[]
    projectLinks            ProjectLink[]

    @@index([userId])
    @@map("project")
}

model ProjectContributor {
    projectId       String
    userId          String
    role            String

    createdAt       DateTime    @default(now())

    project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
    user            Users       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([projectId, userId])
    @@index([projectId])
    @@map("project_contributor")
}

model ProjectLink {
    id              String      @id @default(uuid())
    projectId       String
    name            String
    url             String

    createdAt       DateTime    @default(now())

    project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@index([projectId])
    @@map("project_link")
}

model Folder {
    id              String              @id @default(uuid())
    userId          String
    url             String              @default("")
    name            String
    parentId        String?

    createdAt       DateTime            @default(now())

    parentFolder    Folder?              @relation("ParentChildFolder" ,fields: [parentId], references: [id], onDelete: Cascade)

    inCourses       FolderInCourse[]
    files           File[]
    childrenFolders Folder[]            @relation("ParentChildFolder")

    @@unique([url, name])
    @@index([url])
    @@map("folder")
}


model FolderInCourse {
    folderId        String
    courseId        String

    createdAt       DateTime        @default(now())

    folder          Folder          @relation(fields: [folderId], references: [id], onDelete: Cascade)
    course          Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)

    @@unique([folderId, courseId])
    @@index([courseId])
    @@map("folder_in_course")
}

model File {
    id              String          @id @default(uuid())
    url             String
    name            String
    mimeType        String
    size            Int
    userId          String
    folderId        String

    createdAt       DateTime        @default(now())

    user            Users           @relation(fields: [userId], references: [id], onDelete: Cascade)
    folder          Folder          @relation(fields: [folderId], references: [id], onDelete: Cascade)

    inCourses       FileInCourse[]
    inPosts         FileInPost[]

    @@unique([url, name])
    @@index([url])
    @@map("file")
}

model FileInCourse {
    fileId          String
    courseId        String

    createdAt       DateTime        @default(now())

    file            File            @relation(fields: [fileId], references: [id], onDelete: Cascade)
    course          Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)

    @@unique([fileId, courseId])
    @@index([courseId])
    @@map("file_in_course")
}

model FileInPost {
    fileId          String
    postId          String

    createdAt       DateTime        @default(now())

    file            File            @relation(fields: [fileId], references: [id], onDelete: Cascade)
    post            Post          @relation(fields: [postId], references: [id], onDelete: Cascade)

    @@unique([fileId, postId])
    @@index([postId])
    @@map("file_in_post")
}

model Photo {
    id              Int             @id @default(autoincrement())
    userId          String
    url             String          @default("photo")
    name            String

    createdAt       DateTime        @default(now())

    user            Users           @relation("UploadedPhoto", fields: [userId], references: [id], onDelete: Cascade)
    userAvatar      Users?          @relation("UserAvatar")
    userBackground  Users?          @relation("UserBackground")
    courseThumbnail Course?         @relation()
    experience      Experience?     @relation()
    education       Education?      @relation()
    project         Project?        @relation()

    @@map("photo")
}